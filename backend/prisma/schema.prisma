// Lawnn – Prisma Schema
// Database: PostgreSQL (hosted on Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  student
  client
  admin
}

enum Availability {
  open
  busy
  away
}

enum ApplicationStatus {
  pending
  accepted
  rejected
}

enum ProjectStatus {
  pending        // posted by a client, awaiting admin approval
  open           // approved & visible on the Projects board, accepting applications
  offer_accepted // an applicant was hired
  deposit_paid
  in_progress
  delivered
  completed
  reviewed
  closed         // no longer accepting applications (admin/owner closed it)
}

enum ListingStatus {
  pending
  active
  sold
  removed
}

enum FeedPostStatus {
  pending
  approved
  rejected
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String   // Argon2id hash (legacy bcrypt hashes auto-upgrade on login)
  role        Role     @default(student)
  name        String
  initials    String   @db.VarChar(4)
  avatarColor String   @default("#21326c")
  suspended   Boolean  @default(false) // admin suspension: blocks login + hides public content
  mustChangePassword Boolean @default(false) // force a password reset on next login
  failedLoginAttempts Int      @default(0)  // consecutive failed logins (throttle)
  lockedUntil         DateTime?              // login cooldown expiry (throttle)
  tokenVersion        Int      @default(0)  // bumped to invalidate all existing JWTs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  profile          Profile?
  clientProfile    ClientProfile?
  applications     Application[]
  clientProjects   Project[]       @relation("ClientProjects")
  talentProjects   Project[]       @relation("TalentProjects")
  reviewsGiven          Review[]        @relation("ReviewsGiven")
  reviewsReceived       Review[]        @relation("ReviewsReceived")
  feedPosts             FeedPost[]
  feedComments          Comment[]
  feedLikes             FeedLike[]
  notifications         Notification[]
  listings              MarketplaceListing[]
  offersMade            Offer[]         @relation("OffersMade")
  clientConversations   Conversation[]  @relation("ClientConversations")
  talentConversations   Conversation[]  @relation("TalentConversations")
  adminConversations    Conversation[]  @relation("AdminConversations")
  sentMessages          Message[]       @relation("SentMessages")
  invite                StudentInvite?

  @@map("users")
}

// ─── Student invites (admin-created accounts) ────────────────────────────────
// Admin creates the user with a placeholder password; the student sets their
// real password by following the one-time setup link.
model StudentInvite {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique  // sha256(raw token); raw token never stored
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@map("student_invites")
}

// ─── Talent Profile (students only) ──────────────────────────────────────────

model Profile {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  avatar       String?      // URL to uploaded photo
  bio          String?      @db.Text
  university   String?
  dept         String?
  year         Int?
  isGrad       Boolean      @default(false)
  availability Availability @default(open)
  hourlyRate   Int          @default(0)   // EGP
  walletBalance Int         @default(0)   // EGP, in piastres-free integer
  rating       Float        @default(0)
  reviewCount  Int          @default(0)
  completedJobs Int         @default(0)

  // Relations
  skills        ProfileSkill[]
  portfolio     PortfolioItem[]
  education     Education[]
  experience    Experience[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

// ── Client Profile (clients only) ────────────────────────────────────────────
model ClientProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  company   String?
  bio       String?  @db.Text
  website   String?
  logo      String?  // URL to uploaded logo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_profiles")
}

model ProfileSkill {
  profileId String
  skill     String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([profileId, skill])
  @@map("profile_skills")
}

model PortfolioItem {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  label     String
  color     String  @default("#21326c")
  height    String  @default("medium") // short | medium | tall
  imageUrl  String?
  pdfUrl    String?
  pdfName   String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())

  @@map("portfolio_items")
}

model Education {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  degree    String
  school    String
  years     String

  @@map("education")
}

model Experience {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  role      String
  company   String
  years     String

  @@map("experience")
}

// ─── Project skills & attachments ─────────────────────────────────────────────

model ProjectSkill {
  projectId String
  skill     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, skill])
  @@map("project_skills")
}

model ProjectAttachment {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name     String
  url      String
  mimeType String

  @@map("project_attachments")
}

// ─── Applications ─────────────────────────────────────────────────────────────

model Application {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  status    ApplicationStatus @default(pending)
  note      String            @db.Text

  files    ApplicationFile[]

  createdAt DateTime @default(now())

  @@unique([projectId, userId]) // one application per user per project
  @@index([userId])
  @@map("applications")
}

model ApplicationFile {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  name          String
  url           String
  mimeType      String

  @@map("application_files")
}

// ─── Projects (Escrow) ────────────────────────────────────────────────────────

model Project {
  id        String        @id @default(cuid())
  clientId  String
  client    User          @relation("ClientProjects", fields: [clientId], references: [id])
  talentId  String?
  talent    User?         @relation("TalentProjects", fields: [talentId], references: [id])

  title      String
  brief      String        @db.Text
  budget     Int           // EGP total
  budgetType String        @default("Fixed") // Fixed | Hourly
  category   String        @default("Visuals & Branding")
  vip        Boolean       @default(false)
  status     ProjectStatus @default(pending)

  // Payment tracking (manual InstaPay, admin-confirmed)
  depositAmount        Int?
  depositPaidAt        DateTime?
  depositProofUrl      String?   // private storage path — client's InstaPay screenshot
  finalPaymentProofUrl String?   // private storage path — client's InstaPay screenshot
  paymentRejectionReason String? @db.Text // set when an admin rejects a transfer screenshot
  deliveryNote         String?   @db.Text
  deliveredAt          DateTime?
  clientApproved       Boolean   @default(false)
  completedAt          DateTime?

  // Relations
  skills        ProjectSkill[]
  attachments   ProjectAttachment[]
  applications  Application[]
  reviews       Review[]
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, vip, createdAt])
  @@index([clientId])
  @@index([talentId])
  @@map("projects")
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  authorId    String
  author      User    @relation("ReviewsGiven", fields: [authorId], references: [id])
  recipientId String
  recipient   User    @relation("ReviewsReceived", fields: [recipientId], references: [id])

  rating      Int     // 1–5
  comment     String  @db.Text

  createdAt DateTime @default(now())

  @@unique([projectId, authorId]) // one review per person per project
  @@map("reviews")
}

// ─── Feed ─────────────────────────────────────────────────────────────────────

model FeedPost {
  id       String        @id @default(cuid())
  userId   String
  user     User          @relation(fields: [userId], references: [id])
  content  String        @db.Text
  imageUrl String?
  tags     String[]
  likes    Int           @default(0)   // denormalised count of likedBy
  status   FeedPostStatus @default(pending)

  likedBy  FeedLike[]
  comments Comment[]

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@map("feed_posts")
}

// A user comment on a feed post.
model Comment {
  id         String   @id @default(cuid())
  feedPostId String
  post       FeedPost @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([feedPostId])
  @@map("feed_comments")
}

// In-app notifications surfaced in the bell menu.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("info") // money | star | bag | check | message | info
  title     String
  body      String?  @db.Text
  link      String?  // a frontend view id to open on click (e.g. 'jobs')
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

// One row per (user, post) like — enables true per-user like/unlike.
model FeedLike {
  userId     String
  feedPostId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       FeedPost @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, feedPostId])
  @@map("feed_likes")
}

// ─── Conversations & Messages ─────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())

  // Participants. Client↔student threads use clientId + talentId. Admin↔user
  // threads use adminId + whichever of clientId/talentId matches the target's
  // role. All nullable so a thread can be admin↔client or admin↔student.
  clientId  String?
  client    User?    @relation("ClientConversations", fields: [clientId], references: [id])
  talentId  String?
  talent    User?    @relation("TalentConversations", fields: [talentId], references: [id])
  adminId   String?
  admin     User?    @relation("AdminConversations", fields: [adminId], references: [id])

  // Optional project link
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, talentId]) // one client↔student conversation per pair
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  content        String       @db.Text
  fileUrl        String?
  fileName       String?
  fileMime       String?

  readAt         DateTime?    // null = unread by the other party

  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ─── Marketplace ──────────────────────────────────────────────────────────────

model MarketplaceListing {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation(fields: [sellerId], references: [id])
  title       String
  description String        @db.Text
  price       Int           // EGP
  category    String
  location    String?       // seller-entered location text
  imageUrl    String?       // photo of the item
  fileUrl     String?
  status      ListingStatus @default(pending)

  offers      Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([sellerId])
  @@map("marketplace_listings")
}

// A buyer's offer on a marketplace listing, with an optional seller reply.
model Offer {
  id        String   @id @default(cuid())
  listingId String
  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation("OffersMade", fields: [buyerId], references: [id], onDelete: Cascade)

  amount    Int
  message   String?  @db.Text
  reply     String?  @db.Text
  status    String   @default("pending") // pending | accepted | rejected

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([buyerId])
  @@map("offers")
}

// ─── Site settings (admin-editable key/value config, e.g. homepage image) ─────

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─── News / Insights (admin-authored articles) ───────────────────────────────

model News {
  id        String   @id @default(cuid())
  title     String
  excerpt   String   @db.Text
  author    String   @default("Lawnn Team")
  category  String   @default("Career Advice")
  readTime  String   @default("5 min read")
  color     String   @default("#21326c")
  body      Json     @default("[]")  // array of blocks: { type, text|items }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news")
}
