# ─── Supabase / Postgres ─────────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → Database → Connection string → URI
# Use the "Transaction" pooler URL (port 6543) for serverless/short connections,
# or the direct URL (port 5432) for Prisma migrations.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# For Prisma migrations specifically (direct connection, not pooled)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Make this long and random — e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-this-with-a-long-random-string"
# Token lifetime. Code default is 24h if unset.
JWT_EXPIRES_IN="24h"

# ─── Cookie auth (transition — OFF by default) ───────────────────────────────
# Backend support for httpOnly-cookie sessions exists but is INERT unless
# COOKIE_AUTH=on. Leave it off until the frontend cutover + same-site API host
# are in place (see docs/JWT_COOKIE_MIGRATION.md). When off, auth is the normal
# Authorization: Bearer flow and none of the vars below have any effect.
# COOKIE_AUTH="on"
# SameSite mode: "none" while the API is on a different domain than the frontend
# (requires Secure); switch to "lax" after moving the API to api.lawnndesign.com.
# COOKIE_SAMESITE="none"
# Set once the API is same-site with the frontend, e.g. ".lawnndesign.com".
# COOKIE_DOMAIN=""
# Set to "false" ONLY for local http testing; defaults to true (Secure cookies).
# COOKIE_SECURE="true"
# Optional: override the session cookie lifetime in ms (defaults to 24h).
# COOKIE_MAX_AGE_MS="86400000"

# ─── Supabase Storage (for file uploads) ─────────────────────────────────────
# From: Supabase Dashboard → Settings → API
# SUPABASE_URL is the "Project URL" (e.g. https://abcd1234.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY is under "Project API keys → service_role" — KEEP
# THIS SECRET. It bypasses RLS. Never ship to the browser.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Optional bucket-name overrides. Defaults: lawnn-public, lawnn-private.
# Both must exist in Dashboard → Storage. lawnn-public should be marked Public.
# SUPABASE_PUBLIC_BUCKET="lawnn-public"
# SUPABASE_PRIVATE_BUCKET="lawnn-private"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed frontend origins (for CORS).
# Example for production:
#   FRONTEND_URL="https://lawnndesign.pages.dev,http://localhost:5173"
FRONTEND_URL="http://localhost:5173"
